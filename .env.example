# Application
APP_NAME=Scraper Service
APP_ENV=development

# CORS — comma-separated frontend origins allowed to call this API
CORS_ORIGINS=http://localhost:3800,http://127.0.0.1:3800,http://156.67.105.146:3800

# HTTP / scraping
REQUEST_TIMEOUT=30
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36
MIN_CONTENT_LENGTH=200

# Storage (MongoDB)
# MONGODB_DB_NAME = your shared database (other collections in this DB are untouched)
# MONGODB_COLLECTION_NAME = single collection used only by this app
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=pdf_compare
MONGODB_COLLECTION_NAME=pdf_compare

# Legacy — no longer used for persistence (kept for compatibility)
DATA_DIR=./data

# Batch scraping
BATCH_MAX_URLS=50
BATCH_MAX_CONCURRENT=2

# Workflows (government URL limits per workflow)
WORKFLOW_MIN_URLS=1
WORKFLOW_MAX_URLS=3

# Company document uploads
UPLOAD_MAX_SIZE_MB=20
UPLOAD_ALLOWED_EXTENSIONS=.pdf,.docx,.doc,.txt

# OpenRouter AI (required for compliance comparison)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openai/gpt-4o
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAX_TOKENS=8000
OPENROUTER_TEMPERATURE=0.1
OPENROUTER_TIMEOUT=120
OPENROUTER_APP_TITLE=PDF Compare Compliance

# AI comparison concurrency (keep low to avoid overloading the server)
COMPARISON_MAX_CONCURRENT=1
